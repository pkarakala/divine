{
  "expo": {
    "name": "Divine",
    "slug": "divine",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "divine",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.divine.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Divine uses your camera to take profile photos and verify your membership.",
        "NSPhotoLibraryUsageDescription": "Divine accesses your photo library so you can choose profile photos and upload membership verification documents.",
        "NSLocationWhenInUseUsageDescription": "Divine uses your location to show you members nearby and display approximate distance on profiles. Your exact location is never shown to other users.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.divine.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0D0D14"
        }
      ],
      "expo-notifications",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
