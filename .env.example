# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Demo/reviewer account (optional — login screen hides the demo button if unset)
EXPO_PUBLIC_DEMO_EMAIL=
EXPO_PUBLIC_DEMO_PASSWORD=

# Sentry crash reporting (optional — crash reporting is a no-op when unset)
# Create a React Native project at sentry.io, copy the DSN here
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat subscriptions (optional — paywall shows "coming soon" when unset)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
